engine-strict=true

# Docusaurus (and its plugins) expect a fairly hoisted dependency graph.
# With pnpm's default linker, duplicate module instances can lead to React
# context/provider mismatches during SSG.
node-linker=hoisted
public-hoist-pattern[]=@docusaurus/*
public-hoist-pattern[]=@docsearch/*
public-hoist-pattern[]=react
public-hoist-pattern[]=react-dom
